{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": [
      "react"
    ]
  },
  "include": [
    "index.ts",
    "orm/**/*.ts",
    "react/**/*.ts",
    "../schema/index.ts",
    "../utils/aggregation.ts",
    "../utils/accessControl.ts",
    "test_types/**/*.ts"
  ]
}
