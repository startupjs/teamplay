{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": [
      "react"
    ]
  },
  "include": [
    "index.d.ts",
    "orm/**/*.d.ts",
    "react/**/*.d.ts",
    "test_types/**/*.ts"
  ]
}
