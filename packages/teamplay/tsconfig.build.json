{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "types": [
      "node",
      "react"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.d.ts"
  ]
}
