{
  "name": "@teamplay/utils",
  "type": "module",
  "version": "0.5.0-alpha.0",
  "description": "Isomorphic utils for internal cross-package usage",
  "exports": {
    "./aggregation": {
      "teamplay-ts": "./src/aggregation.ts",
      "types": "./dist/aggregation.d.ts",
      "default": "./dist/aggregation.js"
    },
    "./accessControl": {
      "teamplay-ts": "./src/accessControl.ts",
      "types": "./dist/accessControl.d.ts",
      "default": "./dist/accessControl.js"
    },
    "./uuid": {
      "teamplay-ts": "./src/uuid.cjs",
      "default": "./dist/uuid.cjs"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && rsync -a --include='*/' --include='*.cjs' --exclude='*' src/ dist/ && node ../../scripts/rewrite-dts-extensions.cjs dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "uuid": "^3.4.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
