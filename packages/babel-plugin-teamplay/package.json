{
  "name": "babel-plugin-teamplay",
  "version": "0.4.0",
  "description": "Babel plugin for TeamPlay file-based models",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./loader": "./loader.js",
    "./file-based-models": {
      "node": "./file-based-models.node.js",
      "default": "./file-based-models.js"
    }
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"${NODE_OPTIONS:-} -C teamplay-ts\" vitest run"
  },
  "dependencies": {
    "@babel/helper-module-imports": "^7.0.0",
    "@babel/parser": "^7.0.0",
    "@babel/traverse": "^7.0.0",
    "@startupjs/babel-plugin-eliminator": "^0.62.0-alpha.0",
    "@teamplay/schema": "^0.4.0",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.9.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
